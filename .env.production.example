# ─────────────────────────────────────────────────────────────────────────────
# Pulse — Production Environment Variables
# Copy this file to .env and fill in all values before running docker compose.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=pulse
POSTGRES_USER=pulse
POSTGRES_PASSWORD=change_me_strong_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
# Production Redis is password-protected. This password is used both by the
# redis container (--requirepass) and by the API (REDIS_URL is built in compose).
REDIS_PASSWORD=change_me_redis_password_here

# ── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=4000

# Generate with: openssl rand -base64 32
JWT_SECRET=change_me_jwt_secret_min_32_chars_xxxxxxxxxx
# Generate with: openssl rand -base64 32
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_min_32_chars_xxx

# Comma-separated list of allowed CORS origins (must match your live domain)
ALLOWED_ORIGINS=https://pulseflags.live,https://docs.pulseflags.live,https://demo.pulseflags.live

# ── Dashboard ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.pulseflags.live
NEXT_PUBLIC_DASHBOARD_URL=https://pulseflags.live
NEXT_PUBLIC_DOCS_URL=https://docs.pulseflags.live
NEXT_PUBLIC_EXAMPLE_URL=https://demo.pulseflags.live

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=change_me_nextauth_secret_min_32_chars_xxxxxxx
# The URL where the dashboard is publicly hosted (used by Auth.js for callbacks)
AUTH_URL=https://pulseflags.live

# ── Example / Demo ────────────────────────────────────────────────────────────
# The SDK endpoint that the demo app connects to
NEXT_PUBLIC_PULSE_URL=https://api.pulseflags.live/sdk/v1
# A valid read-only API key generated from your production dashboard
NEXT_PUBLIC_PULSE_API_KEY=ps_live_your_actual_key_here
