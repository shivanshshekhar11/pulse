{
  "name": "@pulse-flags/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "dotenv -e .env.test -- vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "with-dev-env": "dotenv -e .env.development --",
    "with-prod-env": "dotenv -e .env.production --"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@pulse-flags/types": "workspace:*",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.37.0",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "4.0.2",
    "ioredis": "^5.4.2",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@pulse-flags/tsconfig": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.10.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
