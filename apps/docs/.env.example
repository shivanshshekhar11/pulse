# Docs — environment variables reference
# Copy to .env.local or .env.development and fill in your values.

# Fastify API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Dashboard own URL
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001

# Docs site base URL
NEXT_PUBLIC_DOCS_URL=http://localhost:3002

# Example / Demo app URL
NEXT_PUBLIC_EXAMPLE_URL=http://localhost:3003
